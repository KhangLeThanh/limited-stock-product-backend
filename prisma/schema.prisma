datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ReservationStatus {
  PENDING
  COMPLETED
  EXPIRED
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum InventoryLogType {
  RESERVATION_CREATED
  RESERVATION_EXPIRED
  ORDER_CREATED
  STOCK_ADJUSTMENT
}

model Product {
  id        String   @id @default(cuid())
  name      String
  stock     Int
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
}

model Reservation {
  id        String            @id @default(cuid())
  userId    String
  productId String
  quantity  Int
  status    ReservationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime          @default(now())
}

model Order {
  id         String      @id @default(cuid())
  userId     String
  productId  String
  quantity   Int
  totalPrice Float
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())
}

model InventoryLog {
  id          String           @id @default(cuid())
  productId   String
  quantity    Int
  type        InventoryLogType
  description String?
  createdAt   DateTime         @default(now())
}